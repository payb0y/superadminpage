{
  "openapi": "3.0.3",
  "info": {
    "title": "Organization App - Member Management API",
    "version": "1.0.0",
    "description": "Member management endpoints for the Nextcloud Organization app."
  },
  "servers": [
    {
      "url": "/apps/organization",
      "description": "Nextcloud OCS API base path"
    }
  ],
  "paths": {
    "/organizations/{organizationId}": {
      "get": {
        "summary": "Get organization with full member list",
        "operationId": "getOrganization",
        "tags": ["Organization"],
        "parameters": [
          {
            "name": "organizationId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Organization details including members",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "organization": {
                      "$ref": "#/components/schemas/Organization"
                    },
                    "subscription": {
                      "$ref": "#/components/schemas/Subscription"
                    },
                    "plan": { "$ref": "#/components/schemas/Plan" },
                    "members": { "$ref": "#/components/schemas/MemberList" }
                  }
                }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/organizations/{organizationId}/members": {
      "get": {
        "summary": "List all members of an organization",
        "operationId": "getOrganizationMembers",
        "tags": ["Members"],
        "parameters": [
          {
            "name": "organizationId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Member list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "members": { "$ref": "#/components/schemas/MemberList" }
                  }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "post": {
        "summary": "Add an existing Nextcloud user as a member",
        "operationId": "addOrganizationMember",
        "tags": ["Members"],
        "parameters": [
          {
            "name": "organizationId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "userId",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "UID of the existing Nextcloud user"
          }
        ],
        "responses": {
          "200": {
            "description": "Member added",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "members": { "$ref": "#/components/schemas/MemberList" }
                  }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/organizations/{organizationId}/members/{userId}": {
      "delete": {
        "summary": "Remove a member from the organization",
        "operationId": "removeOrganizationMember",
        "tags": ["Members"],
        "parameters": [
          {
            "name": "organizationId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "userId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Member removed",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "members": { "$ref": "#/components/schemas/MemberList" }
                  }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/organizations/{organizationId}/available-users": {
      "get": {
        "summary": "Search for users available to add",
        "operationId": "searchAvailableUsers",
        "tags": ["Members"],
        "parameters": [
          {
            "name": "organizationId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "search",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Search query (matches uid, display name, email)"
          }
        ],
        "responses": {
          "200": {
            "description": "Available users (max 10 results)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "users": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/AvailableUser" }
                    }
                  }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/organizations/{organizationId}/users": {
      "post": {
        "summary": "Create a new Nextcloud user and add as organization member",
        "operationId": "createOrganizationUser",
        "tags": ["Members"],
        "parameters": [
          {
            "name": "organizationId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "userId",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "New user UID"
          },
          {
            "name": "password",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "New user password"
          },
          {
            "name": "displayName",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "email",
            "in": "query",
            "required": false,
            "schema": { "type": "string", "format": "email" }
          }
        ],
        "responses": {
          "200": {
            "description": "User created and added",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "members": { "$ref": "#/components/schemas/MemberList" },
                    "createdUser": {
                      "type": "object",
                      "properties": {
                        "uid": { "type": "string" },
                        "displayName": { "type": "string" },
                        "email": { "type": "string", "nullable": true }
                      }
                    }
                  }
                }
              }
            }
          },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/organizations/{organizationId}/handover": {
      "post": {
        "summary": "Initiate account handover from one member to another",
        "operationId": "handoverOrganizationMember",
        "tags": ["Handover"],
        "parameters": [
          {
            "name": "organizationId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "sourceUserId",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "targetUserId",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "dryRun",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean", "default": false }
          },
          {
            "name": "removeSourceFromGroups",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean", "default": false }
          },
          {
            "name": "remapDeckContent",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean", "default": true }
          }
        ],
        "headers": {
          "Idempotency-Key": {
            "schema": { "type": "string" },
            "description": "Optional idempotency key"
          }
        },
        "responses": {
          "200": { "description": "Handover job created/running" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/organizations/{organizationId}/handover/jobs": {
      "get": {
        "summary": "List handover jobs",
        "operationId": "listHandoverJobs",
        "tags": ["Handover"],
        "parameters": [
          {
            "name": "organizationId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 20 }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 0 }
          }
        ],
        "responses": {
          "200": { "description": "List of handover jobs" },
          "403": { "$ref": "#/components/responses/Forbidden" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/organizations/{organizationId}/handover/jobs/{jobId}": {
      "get": {
        "summary": "Get a specific handover job",
        "operationId": "getHandoverJob",
        "tags": ["Handover"],
        "parameters": [
          {
            "name": "organizationId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": { "description": "Handover job details" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/organizations/{organizationId}/handover/jobs/{jobId}/retry": {
      "post": {
        "summary": "Retry a failed handover job",
        "operationId": "retryHandoverJob",
        "tags": ["Handover"],
        "parameters": [
          {
            "name": "organizationId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "failedStepsOnly",
            "in": "query",
            "required": false,
            "schema": { "type": "boolean", "default": true }
          }
        ],
        "responses": {
          "200": { "description": "Retry result" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/organizations/{organizationId}/handover/jobs/{jobId}/events": {
      "get": {
        "summary": "List events for a handover job",
        "operationId": "listHandoverEvents",
        "tags": ["Handover"],
        "parameters": [
          {
            "name": "organizationId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "jobId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer" }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 50 }
          },
          {
            "name": "offset",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "default": 0 }
          }
        ],
        "responses": {
          "200": { "description": "List of events" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Member": {
        "type": "object",
        "properties": {
          "uid": { "type": "string" },
          "displayName": { "type": "string" },
          "email": { "type": "string", "nullable": true },
          "role": { "type": "string", "enum": ["member", "admin"] }
        }
      },
      "MemberList": {
        "type": "array",
        "items": { "$ref": "#/components/schemas/Member" }
      },
      "AvailableUser": {
        "type": "object",
        "properties": {
          "uid": { "type": "string" },
          "displayName": { "type": "string" },
          "email": { "type": "string", "nullable": true }
        }
      },
      "Organization": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "type": { "type": "string" },
          "adminUid": { "type": "string", "nullable": true }
        }
      },
      "Subscription": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "status": {
            "type": "string",
            "enum": ["active", "paused", "cancelled", "expired"]
          },
          "startedAt": { "type": "string" },
          "endedAt": { "type": "string" }
        }
      },
      "Plan": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "maxMembers": { "type": "integer" }
        }
      }
    },
    "responses": {
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "ocs": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "type": "object",
                      "properties": {
                        "statuscode": { "type": "integer", "example": 404 }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "Forbidden": {
        "description": "Access denied",
        "content": {
          "application/json": {
            "schema": {
              "type": "object",
              "properties": {
                "ocs": {
                  "type": "object",
                  "properties": {
                    "meta": {
                      "type": "object",
                      "properties": {
                        "statuscode": { "type": "integer", "example": 403 }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
